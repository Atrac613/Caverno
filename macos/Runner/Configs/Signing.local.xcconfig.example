// Copy this file to Signing.local.xcconfig for local release signing.
// Signing.local.xcconfig is ignored because it may contain team-specific
// release signing settings.

// Example:
// DEVELOPMENT_TEAM = YOURTEAMID
// CODE_SIGN_STYLE = Manual
// CODE_SIGN_IDENTITY = Developer ID Application
// OTHER_CODE_SIGN_FLAGS = $(inherited) --timestamp
// SPARKLE_FEED_URL = https://updates.example.com/caverno/macos/appcast.xml
// SPARKLE_PUBLIC_ED_KEY = BASE64_PUBLIC_ED25519_KEY_FROM_SPARKLE
